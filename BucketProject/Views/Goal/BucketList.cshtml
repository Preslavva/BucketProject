@model GoalsPageViewModel
@using Newtonsoft.Json

<h2>Bucket List</h2>

@if (!string.IsNullOrEmpty(ViewBag.ErrorMessage as string))
{
    <div class="alert alert-danger">
        @ViewBag.ErrorMessage
    </div>
}

@{
    var brokenDownGoals = TempData["SubGoals"] != null
        ? JsonConvert.DeserializeObject<List<GoalViewModel>>(TempData["SubGoals"].ToString())
        : new List<GoalViewModel>();
    string subGoalForId = TempData["SubGoalForId"]?.ToString();
    if (brokenDownGoals.Any())
        TempData["SubGoals"] = JsonConvert.SerializeObject(brokenDownGoals);
    if (!string.IsNullOrEmpty(subGoalForId))
        TempData["SubGoalForId"] = subGoalForId;
}


<form method="post" asp-controller="Goal" asp-action="CreateBucketListGoal">
    <div class="input-container">
        <input type="text" name="Description" required />
        <label class="label">Enter Goal</label>
        <div class="underline"></div>
    </div>
    <input type="hidden" name="Category" value="Bucket_list" />
    <select name="Type" required class="form-select mb-3">
        <option value="" disabled selected>Select goal type</option>
        @foreach (var type in (List<string>)ViewBag.AvailableTypes)
        {
            <option value="@type">@type</option>
        }
    </select>

    <button class="btn btn-outline-secondary mb-2"
            type="button"
            data-bs-toggle="collapse"
            data-bs-target="#friendsSelect"
            aria-expanded="false"
            aria-controls="friendsSelect">
        Share With Friends
    </button>

    <div class="collapse mb-3" id="friendsSelect">
        <label>Share With Friends:</label>
        <ul class="list-unstyled">
            @foreach (var f in (List<UserSummaryDTO>)ViewBag.Friends)
            {
                var imgSrc = (f.Picture != null && f.Picture.Length > 0)
                ? $"data:image/jpeg;base64,{Convert.ToBase64String(f.Picture)}"
                : null;

                <li class="mb-1">
                    <label class="d-flex align-items-center">
                        <input type="checkbox"
                               name="friendIds"
                               value="@f.Id"
                               class="form-check-input me-2" />

                        @if (imgSrc != null)
                        {
                            <img src="@imgSrc"
                                 alt="@f.Username"
                                 class="rounded-circle me-2"
                                 style="width:24px; height:24px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2"
                                 style="width:24px; height:24px; font-size:0.75rem; font-weight:bold;">
                                @char.ToUpperInvariant(f.Username[0])
                            </div>
                        }

                        <span>@f.Username</span>
                    </label>
                </li>
            }
        </ul>
    </div>


    <button type="submit" class="btn btn-primary mb-4">Add Goal</button>
</form>

<hr />
<ul class="nav nav-tabs mb-4" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link active" id="personal-tab" data-bs-toggle="tab" data-bs-target="#personal" type="button">
            Personal (@Model.TotalPersonal)
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="shared-tab" data-bs-toggle="tab" data-bs-target="#shared" type="button">
            Shared (@Model.TotalShared)
        </button>
    </li>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link" id="invites-tab" data-bs-toggle="tab" data-bs-target="#invites" type="button">
            Invitations (@Model.PendingInvitations.Count)
        </button>
    </li>
</ul>


<div class="tab-content">


    <div class="tab-pane fade show active" id="personal" role="tabpanel">
        <p>
            <strong>Completed:</strong> @Model.AccomplishedCountPersonal /
            <strong>Total:</strong> @Model.TotalPersonal –
            <strong>Remaining:</strong> @Model.RemainingPersonal
        </p>

        @foreach (var goal in Model.Goals)
        {
            <div class="goal-item mb-3 p-2 border">


                <form method="post" asp-action="ChangeGoalStatusBucketList" style="display:inline; margin-left:10px;">
                    <input type="hidden" name="Id" value="@goal.Id" />
                    <label>
                        <input type="checkbox"
                               name="isDone" value="true"
                        @(goal.IsDone ? "checked" : "")
                               onchange="this.form.submit()" />
                        Done
                    </label>
                </form>

                <form method="post" asp-action="EditBucketListGoal" style="display:inline;">
                    <input type="hidden" name="Id" value="@goal.Id" />
                    <input type="text" name="Description" value="@goal.Description" />
                    <button type="submit">Edit</button>
                </form>


                <form method="post" asp-action="DeleteGoalBucketList" style="display:inline; margin-left:10px;"
                      onsubmit="return confirm('Are you sure you want to delete this goal?');">
                    <input type="hidden" name="Id" value="@goal.Id" />
                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                </form>

                <form method="post" asp-action="BreakDownGoalBucketList" asp-controller="Goal" style="display:inline; margin-left:10px;">
                    <input type="hidden" name="id" value="@goal.Id" />
                    <button type="submit">Break Down</button>
                </form>
                @if (goal.IsDone && goal.CompletedAt.HasValue)
                {
                    <span class="ml-2 text-muted">
                        Completed on @goal.CompletedAt.Value.ToString("MMMM dd, yyyy")
                    </span>
                }

                @if (subGoalForId == goal.Id.ToString() && brokenDownGoals.Any())
                {
                    <div class="mt-2 p-2 bg-light">
                        @foreach (var sub in brokenDownGoals)
                        {
                            <div class="d-flex align-items-center mb-1">
                                <form method="post" asp-action="CreateBucketListGoal" class="d-flex me-2">
                                    <input type="text" name="Description" value="@sub.Description" required />
                                    <input type="hidden" name="OriginalDescription" value="@sub.Description" />
                                    <input type="hidden" name="Category" value="Bucket_list" />
                                    <input type="hidden" name="Type" value="@goal.Type" />
                                    <input type="hidden" name="ParentGoalId" value="@goal.Id" />
                                    <button type="submit">Add</button>
                                </form>
                                <form method="post" asp-action="RemoveSubGoalFromBreakdownBucketList">
                                    <input type="hidden" name="description" value="@sub.Description" />
                                    <button type="submit">Remove</button>
                                </form>
                            </div>
                        }
                    </div>
                }


                @if (goal.Children?.Any() == true)
                {
                    <div class="ms-4 mt-2 border-start ps-3">
                        @foreach (var sub in goal.Children)
                        {
                            <div class="mb-1">
                                <form method="post" asp-action="EditBucketListGoal" style="display:inline;">
                                    <input type="hidden" name="Id" value="@sub.Id" />
                                    <input type="text" name="Description" value="@sub.Description" required />
                                    <button type="submit">Save</button>
                                </form>
                                <form method="post" asp-action="ChangeGoalStatusBucketList" style="display:inline; margin-left:10px;">
                                    <input type="hidden" name="Id" value="@sub.Id" />
                                    <label>
                                        <input type="checkbox"
                                               name="isDone" value="true"
                                        @(sub.IsDone ? "checked" : "")
                                               onchange="this.form.submit()" />
                                        Done
                                    </label>
                                </form>
                                <form method="post" asp-action="DeleteGoalBucketList" style="display:inline; margin-left:10px;"
                                      onsubmit="return confirm('Are you sure you want to delete this goal?');">
                                    <input type="hidden" name="Id" value="@goal.Id" />
                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                </form>
                                @if (sub.IsDone && sub.CompletedAt.HasValue)
                                {
                                    <span class="ml-2 text-muted">
                                        Completed on @goal.CompletedAt.Value.ToString("MMMM dd, yyyy")
                                    </span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        }
    </div>

    <div class="tab-pane fade" id="shared" role="tabpanel">
        <p>
            <strong>Completed:</strong> @Model.AccomplishedCountShared /
            <strong>Total:</strong> @Model.TotalShared –
            <strong>Remaining:</strong> @Model.RemainingShared
        </p>

        @if (!Model.SharedGoals.Any())
        {
            <p>No shared goals this week.</p>
        }
        else
        {
            @foreach (var goal in Model.SharedGoals)
            {
                <div class="goal-item mb-3 p-2 border">

                    <form method="post" asp-action="ChangeGoalStatusBucketList" class="d-inline">
                        <input type="hidden" name="Id" value="@goal.Id" />
                        <input type="checkbox" name="isDone" value="true" class="form-check-input" @(goal.IsDone ? "checked" : "") onchange="this.form.submit()" />
                        Done
                    </form>



                    @if (goal.OwnerId == ViewBag.CurrentUserId)
                    {


                        <form method="post" asp-action="EditBucketListGoal" class="d-inline ms-2">
                            <input type="hidden" name="Id" value="@goal.Id" />
                            <input type="text" name="Description" value="@goal.Description" required />
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Edit</button>
                        </form>

                        <form method="post" asp-action="DeleteGoalBucketList" style="display:inline; margin-left:10px;"
                              onsubmit="return confirm('Are you sure you want to delete this goal?');">
                            <input type="hidden" name="Id" value="@goal.Id" />
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>

                        <form method="post" asp-action="BreakDownGoalBucketList" class="d-inline ms-2">
                            <input type="hidden" name="id" value="@goal.Id" />
                            <button type="submit" class="btn btn-sm btn-outline-warning">Break Down</button>
                        </form>
                    }
                    else
                    {
                        <span class="mx-2">@goal.Description</span>
                    }

                    @if (goal.IsDone && goal.CompletedAt.HasValue)
                    {
                        <span class="ml-2 text-muted">
                            Completed on @goal.CompletedAt.Value.ToString("MMMM dd, yyyy")
                        </span>
                    }

                    <div class="mt-2">
                        <strong>Also shared with:</strong>
                        @if (goal.Recipients == null || !goal.Recipients.Any())
                        {
                            <span class="text-muted">no one else</span>
                        }
                        else
                        {
                            <ul class="list-inline mb-0">
                                @foreach (var u in goal.Recipients)
                                {
                                    var imgSrc = (u.Picture != null && u.Picture.Length > 0)
                                    ? $"data:image/jpeg;base64,{Convert.ToBase64String(u.Picture)}"
                                    : null;

                                    <li class="list-inline-item text-center me-2">
                                        @if (imgSrc != null)
                                        {
                                            <img src="@imgSrc"
                                                 alt="@u.Username"
                                                 class="rounded-circle mb-1"
                                                 style="width:32px; height:32px; object-fit: cover;" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center mb-1 mx-auto"
                                                 style="width:32px; height:32px; font-size:0.9rem; font-weight:bold;">
                                                @char.ToUpperInvariant(u.Username[0])
                                            </div>
                                        }
                                        <small>@u.Username</small>
                                    </li>
                                }
                            </ul>
                        }
                    </div>


                    @if (goal.OwnerId == ViewBag.CurrentUserId)
                    {
                        @if (subGoalForId == goal.Id.ToString() && brokenDownGoals.Any())
                        {
                            <div class="mt-2 p-2 bg-light">
                                @foreach (var sub in brokenDownGoals)
                                {
                                    <div class="d-flex align-items-center mb-1">
                                        <form method="post" asp-action="CreateBucketListGoal" class="d-flex me-2">
                                            <input type="text" name="Description" value="@sub.Description" required />
                                            <input type="hidden" name="OriginalDescription" value="@sub.Description" />
                                            <input type="hidden" name="Category" value="Week" />
                                            <input type="hidden" name="Type" value="@goal.Type" />
                                            <input type="hidden" name="ParentGoalId" value="@goal.Id" />
                                            @if (goal.Recipients != null)
                                            {
                                                @foreach (var friend in goal.Recipients)
                                                {
                                                    <input type="hidden" name="friendIds[]" value="@friend.Id" />
                                                }
                                            }
                                            <button type="submit">Add</button>
                                        </form>
                                        <form method="post" asp-action="RemoveSubGoalFromBreakdownBucketList">
                                            <input type="hidden" name="description" value="@sub.Description" />
                                            <button type="submit">Remove</button>
                                        </form>
                                    </div>
                                }
                            </div>
                        }
                    }

                    @if (goal.Children?.Any() == true)
                    {
                        <div class="ms-4 mt-2 border-start ps-3">
                            @foreach (var sub in goal.Children)
                            {
                                <div class="mb-1">
                                    <form method="post" asp-action="ChangeGoalStatusBucketList" class="d-inline">
                                        <input type="hidden" name="Id" value="@sub.Id" />
                                        <input type="checkbox" name="isDone" value="true" class="form-check-input" @(sub.IsDone ? "checked" : "") onchange="this.form.submit()" />
                                    </form>

                                    @if (sub.OwnerId == ViewBag.CurrentUserId)
                                    {
                                        <form method="post" asp-action="EditBucketListGoal" class="d-inline ms-2">
                                            <input type="hidden" name="Id" value="@sub.Id" />
                                            <input type="text" name="Description" value="@sub.Description" required class="form-control form-control-sm d-inline-block w-auto" />
                                            <button class="btn btn-sm btn-outline-secondary">Save</button>
                                        </form>
                                        <form method="post" asp-action="DeleteGoalBucketList" style="display:inline; margin-left:10px;"
                                              onsubmit="return confirm('Are you sure you want to delete this goal?');">
                                            <input type="hidden" name="Id" value="@goal.Id" />
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    }
                                    else
                                    {
                                        <span class="ms-2">@sub.Description</span>
                                    }
                                </div>

                                @if (sub.IsDone && sub.CompletedAt.HasValue)
                                {
                                    <span class="ml-2 text-muted">
                                        Completed on @sub.CompletedAt.Value.ToString("MMMM dd, yyyy")
                                    </span>
                                }
                            }
                        </div>
                    }


                </div>
            }


        }
        <hr />
        <br />
        <h5>Invitations You’ve Sent</h5>
        @if (!Model.SentInvitations.Any())
        {
            <p class="text-muted">No sent invitations.</p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var inv in Model.SentInvitations)
                {
                    <li class="list-group-item mb-2 position-relative" id="invite-@inv.InvitationId">

                        <form asp-action="DismissNotificationBucketList" method="post" class="position-absolute top-0 end-0 m-2">

                            <input type="hidden" name="goalId" value="@inv.GoalId" />
                            <input type="hidden" name="notificationType" value="Invite" />
                            <input type="hidden" name="triggeredByUserId" value="@inv.TriggeredByUserId" />
                            <button type="submit" class="btn-close" aria-label="Dismiss invitation notification"></button>
                        </form>

                        <div class="me-4">
                            <em>@inv.GoalDescription</em><br />
                            <small>sent @inv.CreatedAt.ToShortDateString()</small>
                            <small class="ms-3">Status: @inv.Status</small>
                            <small class="ms-3">Recipient: @inv.InvitedUsername</small>
                            @if (!string.IsNullOrEmpty(inv.ParentGoalDescription))
                            {
                                <div>
                                    <small class="text-muted">
                                        Parent goal: @inv.ParentGoalDescription
                                    </small>
                                </div>
                            }
                        </div>
                    </li>
                }

            </ul>
        }
    </div>
    <div class="tab-pane fade" id="invites" role="tabpanel">
        <p>
            <strong>Pending Invitations:</strong> @Model.PendingInvitations.Count
        </p>

        @if (!Model.PendingInvitations.Any())
        {
            <p class="text-muted">No pending invitations.</p>
        }
        else
        {
            <ul class="list-group">
                @foreach (var inv in Model.PendingInvitations)
                {
                    <li class="list-group-item d-flex justify-content-between align-items-center">
                        <div>
                            <strong>@inv.InviterUsername</strong> invited you to:<br />
                            <em>@inv.GoalDescription</em>
                            @if (!string.IsNullOrEmpty(inv.ParentGoalDescription))
                            {
                                <div>
                                    <small class="text-muted">
                                        Parent goal: @inv.ParentGoalDescription
                                    </small>
                                </div>
                            }

                        </div>
                        <div class="d-flex">
                            <form method="post" asp-action="RespondInvitationBucketList" class="me-1">
                                <input type="hidden" name="invitationId" value="@inv.InvitationId" />
                                <input type="hidden" name="accept" value="true" />
                                <button type="submit" class="btn btn-sm btn-success">Accept</button>
                            </form>
                            <form method="post" asp-action="RespondInvitationBucketList">
                                <input type="hidden" name="invitationId" value="@inv.InvitationId" />
                                <input type="hidden" name="accept" value="false" />
                                <button type="submit" class="btn btn-sm btn-danger">Decline</button>
                            </form>
                        </div>
                    </li>
                }
            </ul>
        }


    </div>

</div>

