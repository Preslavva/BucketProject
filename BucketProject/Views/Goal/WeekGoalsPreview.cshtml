@model GoalsPageViewModel

@{
    Layout = "_Layout";
    ViewBag.HideHeaderFooter = true;
}

<h2>Weekly Goals</h2>


<hr />

<ul style="list-style-type:none;">
    @foreach (var goal in Model.Goals)
    {
        <li style="list-style-type:none;">
            <span class="custom-checkbox @(goal.IsDone ? "checked" : "")"></span> @goal.Description



            @if (goal.Children?.Any() == true)
            {
                <ul style="list-style-type:none;">
                    @foreach (var sub in goal.Children)
                    {
                        <li style="list-style-type:none;">
                            <span class="custom-checkbox @(sub.IsDone ? "checked" : "")"></span> @sub.Description

                        </li>
                    }
                </ul>
            }
        </li>
    }
    @foreach (var goal in Model.SharedGoals)
    {
        <li style="list-style-type:none;">
            <span class="custom-checkbox @(goal.IsDone ? "checked" : "")"></span> @goal.Description

            @if (goal.Children?.Any() == true)
            {
                <ul style="list-style-type:none;">
                    @foreach (var sub in goal.Children)
                    {
                        <li style="list-style-type:none;">
                            <span class="custom-checkbox @(sub.IsDone ? "checked" : "")"></span> @sub.Description
                        </li>
                    }
                </ul>
            }
        </li>
    }
</ul>
