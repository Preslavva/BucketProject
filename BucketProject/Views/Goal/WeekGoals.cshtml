@model GoalsPageViewModel
@using Newtonsoft.Json

<h2>Weekly Goals</h2>

@{
    var brokenDownGoals = TempData["SubGoals"] != null
        ? JsonConvert.DeserializeObject<List<GoalViewModel>>(TempData["SubGoals"].ToString())
        : new List<GoalViewModel>();

    string subGoalForId = TempData["SubGoalForId"]?.ToString();

    if (brokenDownGoals.Any())
        TempData["SubGoals"] = JsonConvert.SerializeObject(brokenDownGoals);

    if (!string.IsNullOrEmpty(subGoalForId))
        TempData["SubGoalForId"] = subGoalForId;
}

<p>
    <strong>Completed:</strong> @Model.AccomplishedCount /
    <strong>Total:</strong> @Model.Total &ndash;
    <strong>Remaining:</strong> @Model.Remaining
</p>

<form method="post" asp-controller="Goal" asp-action="CreateWeekGoal">
    <input type="text" name="Description" placeholder="Enter your goal..." required />
    <input type="hidden" name="Category" value="Week" />
    <select name="Type" required>
        <option value="" disabled selected>Select goal type</option>
        @foreach (var type in (List<string>)ViewBag.AvailableTypes ?? new List<string>())
        {
            <option value="@type">@type</option>
        }
    </select>
    <button type="submit">Add Goal</button>
</form>

<hr />

@foreach (var goal in Model.Goals)
{
    <div class="goal-item" style="margin-bottom:1em; padding:.5em; border:1px solid #ccc;">

        <form method="post" asp-action="EditWeekGoal" style="display:inline;">
            <input type="hidden" name="Id" value="@goal.Id" />
            <input type="text" name="Description" value="@goal.Description" required />
            <button type="submit">Save</button>
        </form>

        <form method="post" asp-action="ChangeGoalStatusWeek" style="display:inline; margin-left:10px;">
            <input type="hidden" name="Id" value="@goal.Id" />
            <label>
                <input type="checkbox"
                       name="isDone"
                       value="true"
                @(goal.IsDone ? "checked" : "")
                       onchange="this.form.submit()" />
                Done
            </label>
        </form>

        <form method="post" asp-action="DeleteGoalWeek" style="display:inline; margin-left:10px;">
            <input type="hidden" name="Id" value="@goal.Id" />
            <button type="submit">Delete</button>
        </form>

        <form method="post" asp-action="BreakDownGoalWeek" asp-controller="Goal" style="display:inline; margin-left:10px;">
            <input type="hidden" name="id" value="@goal.Id" />
            <button type="submit">Break Down</button>
        </form>


        @if (subGoalForId == goal.Id.ToString() && brokenDownGoals.Any())
        {
            <div style="margin-top:1em; padding:.5em; background:#f9f9f9;">
                @foreach (var sub in brokenDownGoals)
                {
                    <div class="sub-goal-entry" style="display:flex; gap:10px; margin-bottom:.5em;">

                        <form method="post" asp-action="CreateWeekGoal" style="flex:1; display:flex; gap:10px; align-items:center;">
                            <input type="text" name="Description" value="@sub.Description" required />
                            <input type="hidden" name="OriginalDescription" value="@sub.Description" />
                            <input type="hidden" name="Category" value="Week" />
                            <input type="hidden" name="Type" value="@goal.Type" />
                            <input type="hidden" name="ParentGoalId" value="@goal.Id" />
                            <button type="submit">Add</button>
                        </form>

                        <form method="post" asp-controller="Goal" asp-action="RemoveSubGoalFromBreakdownWeek">
                            <input type="hidden" name="description" value="@sub.Description" />
                            <button type="submit">Remove</button>
                        </form>

                    </div>
                }
            </div>
        }

        @if (goal.Children?.Any() == true)
        {
            <div class="sub-goals" style="margin-left:2em; margin-top:1em; border-left:2px dashed #ccc; padding-left:1em;">
                @foreach (var sub in goal.Children)
                {
                    <div class="sub-goal" style="margin-bottom:.5em;">

                        <form method="post" asp-action="EditWeekGoal" style="display:inline;">
                            <input type="hidden" name="Id" value="@sub.Id" />
                            <input type="text" name="Description" value="@sub.Description" required />
                            <button type="submit">Save</button>
                        </form>

                        <form method="post" asp-action="ChangeGoalStatusWeek" style="display:inline; margin-left:10px;">
                            <input type="hidden" name="Id" value="@sub.Id" />
                            <label>
                                <input type="checkbox"
                                       name="isDone"
                                       value="true"
                                @(sub.IsDone ? "checked" : "")
                                       onchange="this.form.submit()" />
                                Done
                            </label>
                        </form>

                        <form method="post" asp-action="DeleteGoalWeek" style="display:inline; margin-left:10px;">
                            <input type="hidden" name="Id" value="@sub.Id" />
                            <button type="submit">Delete</button>
                        </form>

                    </div>
                }
            </div>
        }

    </div>
}
