@model List<HistoryViewModel>

@{
    int currentPage = ViewBag.CurrentPage ?? 1;
    int pageSize = ViewBag.PageSize ?? 4;
    bool hasMore = ViewBag.HasMore ?? false;
}

@if (!Model.Any())
{
    <p class="text-muted">No goals found.</p>
}
else
{
    <ul class="list-group">
        @foreach (var goal in Model)
        {
            <li class="list-group-item mb-2">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <strong>@goal.Description</strong><br />
                        <small class="text-muted">Created At: @goal.CreatedAt.ToShortDateString()</small><br />
                        <small class="text-muted">Deadline: @goal.Deadline?.ToShortDateString()</small>

                        @if (goal.Recipients != null && goal.Recipients.Any())
                        {
                            <div class="mt-2">
                                <small class="text-muted">Shared with:</small>
                                @foreach (var u in goal.Recipients)
                                {
                                    <span class="ms-2 d-inline-flex align-items-center">
                                        @if (u.Picture != null && u.Picture.Length > 0)
                                        {
                                            <img src="data:image/png;base64,@Convert.ToBase64String(u.Picture)"
                                                 alt="@u.Username"
                                                 width="24" height="24"
                                                 class="rounded-circle me-1" />
                                        }
                                        else
                                        {
                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-1"
                                                 style="width:24px; height:24px; font-size:0.8rem;">
                                                @u.Username.Substring(0, 1).ToUpper()
                                            </div>
                                        }
                                        <span>@u.Username</span>
                                    </span>
                                }
                            </div>
                        }
                    </div>

                    <div class="text-end">
                        @if (goal.IsDone)
                        {
                            <span class="badge bg-success">Completed</span>
                            <br />
                            <small class="text-muted">on @goal.CompletedAt?.ToShortDateString()</small>
                        }
                        else
                        {
                            <span class="badge bg-danger">Not Completed</span>
                        }
                    </div>
                </div>
            </li>
        }
    </ul>

    @if (hasMore)
    {
        <div class="text-center mt-3">
            <button id="loadMoreBtn" class="btn btn-outline-primary"
                    data-page="@currentPage" data-pagesize="@pageSize">
                Load More
            </button>
        </div>
    }
}
