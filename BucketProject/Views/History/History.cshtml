@{
    ViewData["Title"] = "Goal History";
    var goalTypes = ViewBag.GoalTypes as List<string> ?? new List<string>();
    var categories = ViewBag.Categories as List<string> ?? new List<string>();
}

<h2 class="text-center my-4">Goal History</h2>

<div class="container mb-4">
    <div class="row mb-3">
        <div class="col-md-3">
            <input type="text" id="historyDateRange" class="form-control" placeholder="Select date range" readonly />
        </div>
        <div class="col-md-3">
            <select id="goalTypeFilter" class="form-select">
                <option value="">All Goal Types</option>
                @foreach (var type in goalTypes)
                {
                    <option value="@type">@type</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <select id="categoryFilter" class="form-select">
                <option value="">All Categories</option>
                @foreach (var category in categories)
                {
                    <option value="@category">@category</option>
                }
            </select>
        </div>
        <div class="col-md-3">
            <button id="clearFilters" class="btn btn-outline-secondary w-100">Clear Filters</button>
        </div>
    </div>

    <div id="historyContainer" class="mt-4 text-center">
        <p class="text-muted">Please select a date range or filters to view your goal history.</p>
    </div>
</div>

@section Scripts {
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/litepicker/dist/litepicker.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/litepicker/dist/litepicker.css" rel="stylesheet" />

    <script>
        $(document).ready(function () {
            const picker = new Litepicker({
                element: document.getElementById('historyDateRange'),
                singleMode: false,
                format: 'YYYY-MM-DD',
                maxDate: new Date(),
                setup: (picker) => {
                    picker.on('selected', () => {
                        loadHistory(1); 
                    });
                }
            });

            $('#goalTypeFilter, #categoryFilter').on('change', function () {
                loadHistory(1); 
            });

            $('#clearFilters').on('click', function () {
                $('#historyDateRange').val('');
                picker.clearSelection();
                $('#goalTypeFilter').val('');
                $('#categoryFilter').val('');
                $('#historyContainer').html('<p class="text-muted">Please select a date range or filters to view your goal history.</p>');
            });

            $(document).on('click', '.page-link', function () {
                const page = $(this).data('page');
                loadHistory(page);
            });

            function loadHistory(page) {
                const range = $('#historyDateRange').val();
                let startDate = null, endDate = null;

                if (range.includes(' - ')) {
                    const parts = range.split(' - ');
                    startDate = parts[0];
                    endDate = parts[1];
                }

                const goalType = $('#goalTypeFilter').val() || null;
                const category = $('#categoryFilter').val() || null;

                if (!startDate && !endDate && !goalType && !category) {
                    $('#historyContainer').html('<p class="text-muted">Please select a date range or filters to view your goal history.</p>');
                    return;
                }

                $.ajax({
                    url: '/History/FilterHistory',
                    type: 'GET',
                    data: {
                        startDate: startDate,
                        endDate: endDate,
                        goalType: goalType,
                        category: category,
                        page: page,
                        pageSize: 4
                    },
                    success: function (html) {
                        $('#historyContainer').html(html);
                    },
                    error: function () {
                        $('#historyContainer').html('<p class="text-danger">Failed to load history.</p>');
                    }
                });
            }
        });
    </script>
}

