@model Dictionary<string, Dictionary<string, Dictionary<string, List<HistoryViewModel>>>>

@{
    var username = ViewBag.Username as string;
}

<div class="container mt-4">
    @if (Model != null && Model.Any())
    {
        foreach (var categoryGroup in Model)
        {
            <h3 class="mt-5">@categoryGroup.Key Goals</h3>

            foreach (var timeGroup in categoryGroup.Value.OrderByDescending(g => g.Key))
            {
                <h4 class="mt-3">@timeGroup.Key</h4>

                foreach (var typeGroup in timeGroup.Value)
                {
                    <h5>@typeGroup.Key</h5>
                    <ul class="list-group mb-3">
                        @foreach (var goal in typeGroup.Value)
                        {
                            <li class="list-group-item">
                                <div class="d-flex justify-content-between">

                                    <div>
                                        <strong>@goal.Description</strong><br />
                                        <small class="text-muted">
                                            Deadline: @goal.Deadline?.ToShortDateString()
                                        </small>

                                        @if (goal.Recipients != null && goal.Recipients.Any())
                                        {
                                            <div class="mt-1">
                                                <small class="text-muted">Shared with:</small>
                                                @foreach (var u in goal.Recipients)
                                                {
                                                    <span class="ms-2 align-middle d-inline-flex">
                                                       
                                                        @if (u.Picture != null && u.Picture.Length > 0)
                                                        {
                                                            <img src="data:image/png;base64,@Convert.ToBase64String(u.Picture)"
                                                                 alt="@u.Username"
                                                                 width="24" height="24"
                                                                 class="rounded-circle me-1" />
                                                        }
                                                        else
                                                        {
                                                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-1"
                                                                 style="width:24px; height:24px; font-size:0.8rem;">
                                                                @u.Username.Substring(0, 1).ToUpper()
                                                            </div>
                                                        }
                                                        <span class="align-self-center">@u.Username</span>
                                                    </span>
                                                }
                                            </div>
                                        }
                                    </div>

                                
                                    <div class="text-end">
                                        @if (goal.IsDone)
                                        {
                                            <span class="badge bg-success">Completed</span>

                                            <br />
                                            <small class="text-muted">
                                                on @goal.CompletedAt?.ToShortDateString()
                                            </small>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Not Completed</span>
                                        }
                                    </div>

                                </div> 
                            </li>

                        }
                    </ul>
                }
            }
        }
    }
    else
    {
        <p class="text-muted">No expired goals found.</p>
    }
</div>
