@{
    ViewData["Title"] = "Manager Search";
}
@model List<User>

<h2 style="text-align: center; margin-bottom: 40px;">Manager Search</h2>

<div style="max-width: 1000px; margin: 0 auto 40px auto;">
    <form id="userFilterForm" method="get" class="search-form mb-4">
        <input type="text" name="query" placeholder="Search by username or email"
               value="@Context.Request.Query["query"]" class="form-input" />

        @{
            var genderQuery = Context.Request.Query["gender"].ToString();
            var nationalityQuery = Context.Request.Query["nationality"].ToString();
        }

        <select name="gender" class="form-input">
            <option value="">All Genders</option>
            @foreach (var gen in (ViewBag.Genders as List<string> ?? new List<string>()))
            {
                <option value="@gen" selected="@(gen == genderQuery)">@gen</option>
            }
        </select>

        <select name="nationality" class="form-input">
            <option value="">All Nationalities</option>
            @foreach (var nat in (ViewBag.Nationalities as List<string> ?? new List<string>()))
            {
                <option value="@nat" selected="@(nat == nationalityQuery)">@nat</option>
            }
        </select>

        <input type="number" name="minAge" placeholder="Min Age"
               value="@Context.Request.Query["minAge"]" class="form-input" />

        <input type="number" name="maxAge" placeholder="Max Age"
               value="@Context.Request.Query["maxAge"]" class="form-input" />

        <input type="date" name="createdAfter"
               value="@Context.Request.Query["createdAfter"]" class="form-input" />
    </form>

    <div id="userTableContainer">
        @if ((Model != null && Model.Any()) )
        {
            @await Html.PartialAsync("_UserTablePartial", Model)
        }
        else
        {
            <p class="text-center text-muted">Please apply a filter to search for users.</p>
        }

    </div>

   

   
</div>



