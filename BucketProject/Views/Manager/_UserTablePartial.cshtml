@model List<User>

@if (!Model.Any())
{
    <p>No users found.</p>
}
else
{
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>Profile</th>
                <th>Username</th>
                <th>Email</th>
                <th>Gender</th>
                <th>Nationality</th>
                <th>Age</th>
                <th>Created At</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                var age = DateTime.Today.Year - user.DateOfBirth.Year;
                if (user.DateOfBirth > DateTime.Today.AddYears(-age)) age--;

                <tr>
                    <td>
                        @if (user.Picture != null && user.Picture.Length > 0)
                        {
                            var imgSrc = $"data:image/jpeg;base64,{Convert.ToBase64String(user.Picture)}";
                            <img src="@imgSrc" alt="User avatar" style="width: 40px; height: 40px; object-fit: cover; border-radius: 50%;" />
                        }
                        else
                        {
                            <span style="color: #888; font-style: italic;">No picture</span>
                        }
                    </td>
                    <td>@user.Username</td>
                    <td>@user.Email</td>
                    <td>@user.Gender</td>
                    <td>@user.Nationality</td>
                    <td>@age</td>
                    <td>@user.CreatedAt.ToString("yyyy-MM-dd")</td>
                </tr>
            }
        </tbody>
    </table>

    @if (ViewBag.TotalPages > 1)
    {
        <div class="pagination mt-3">
            @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
            {
                var activeClass = i == (int)ViewBag.CurrentPage ? "active-page" : "";
                <a href="javascript:void(0);" class="page-link @activeClass" data-page="@i">@i</a>
            }
        </div>
    }
}

