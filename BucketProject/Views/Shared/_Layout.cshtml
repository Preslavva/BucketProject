@{
    var username = Context.Session.GetString("Username");
    var role = Context.Session.GetString("Role");
    var hideHeaderFooter = ViewBag.HideHeaderFooter ?? false;
    var pageTitle = ViewData["Title"] ?? "BucketProject";
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@pageTitle - BucketProject</title>

    <!-- Bootstrap and site styles -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BucketProject.styles.css" asp-append-version="true" />
</head>
<body>

    @if (!hideHeaderFooter)
    {
        <header>
            <nav class="navbar navbar-expand-lg navbar-light bg-white border-bottom shadow-sm mb-3">
                <div class="container-fluid">
                    @if (string.IsNullOrEmpty(username))
                    {
                        <a class="navbar-brand d-flex align-items-center" asp-controller="User" asp-action="LogIn">
                            <img src="~/images/logo.png"
                                 alt="Logo"
                                 height="80"
                                 class="d-inline-block me-2" />
                        </a>
                    }
                    else if (role?.Equals("User", StringComparison.OrdinalIgnoreCase) == true)
                    {
                        <a class="navbar-brand d-flex align-items-center" asp-controller="Home" asp-action="Index">
                            <img src="~/images/logo.png"
                                 alt="Logo"
                                 height="80"
                                 class="d-inline-block me-2" />
                        </a>


                    }
                    else if (role?.Equals("Manager", StringComparison.OrdinalIgnoreCase) == true)
                    {
                        <a class="navbar-brand d-flex align-items-center" asp-controller="Manager" asp-action="Manager">
                            <img src="~/images/logo.png"
                                 alt="Logo"
                                 height="80"
                                 class="d-inline-block me-2" />
                        </a>

                    }

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNav">
                        <ul class="navbar-nav ms-auto gap-lg-2">
      
                            @if (string.IsNullOrEmpty(username))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="User" asp-action="Register">Register</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="User" asp-action="LogIn">Log in</a>
                                </li>
                            }
                      
                            else if (role?.Equals("User", StringComparison.OrdinalIgnoreCase) == true)
                            {
                              
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Goal" asp-action="BucketList">Bucket List</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="History" asp-action="History">History</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Social" asp-action="Social">Social</a>
                                </li>
                                <li class="nav-item dropdown">
                                    <a class="nav-link dropdown-toggle" href="#" id="accountMenu" role="button" data-bs-toggle="dropdown" aria-expanded="false">Account</a>
                                    <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountMenu">
                                        <li><a class="dropdown-item" asp-controller="User" asp-action="Account">Profile</a></li>
                                        <li><a class="dropdown-item" asp-controller="Notification" asp-action="Notification">Notifications</a></li>
                                        <li><hr class="dropdown-divider" /></li>
                                        <li><a class="dropdown-item text-danger" asp-controller="User" asp-action="LogOut">Log out</a></li>
                                    </ul>
                                </li>
                            }
                      
                            else if (role?.Equals("Manager", StringComparison.OrdinalIgnoreCase) == true)
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Manager" asp-action="Manager">Manager Panel</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-danger" asp-controller="User" asp-action="LogOut">Log out</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>

        </header>
    }

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (!hideHeaderFooter)
    {
        <footer class="border-top footer text-muted mt-4">
            <div class="container">
                &copy; 2025 - BucketProject - <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </footer>
    }

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
