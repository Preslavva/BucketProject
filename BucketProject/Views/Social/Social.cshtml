@model SocialViewModel
@{
    ViewData["Title"] = "Social";
}

<h2>Search Users</h2>
<hr></hr>
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text"
               name="searchTerm"
               class="form-control"
               placeholder="Type a username…" />
    </div>
</form>

<div id="staticSections">
    @if (Model.Friends.Any())
    {
        <h3>Your Friends</h3>
        <hr></hr>
        <ul class="list-group mb-4">
            @foreach (var f in Model.Friends)
            {
                var imgSrc = (f.Picture != null && f.Picture.Length > 0)
                ? $"data:image/jpeg;base64,{Convert.ToBase64String(f.Picture)}"
                : null;

                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        @if (imgSrc != null)
                        {
                            <img src="@imgSrc" class="rounded-circle me-2" style="width:32px; height:32px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2"
                                 style="width:32px; height:32px; font-size:0.9rem; font-weight:bold;">
                                @char.ToUpperInvariant(f.Username[0])
                            </div>
                        }
                        <span>@f.Username</span>
                    </div>
                    <form asp-action="RemoveFriend" method="post">
                        <input type="hidden" name="friendId" value="@f.Id" />
                        <button class="btn btn-sm btn-danger">Remove</button>
                    </form>
                </li>
            }
        </ul>
    }

    @if (Model.IncomingRequests.Any())
    {
        <h3>Incoming Friend Requests</h3>
        <hr></hr>
        <ul class="list-group mb-4">
            @foreach (var r in Model.IncomingRequests)
            {
                var imgSrc = (r.Picture != null && r.Picture.Length > 0)
                ? $"data:image/jpeg;base64,{Convert.ToBase64String(r.Picture)}"
                : null;

                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        @if (imgSrc != null)
                        {
                            <img src="@imgSrc" class="rounded-circle me-2" style="width:32px; height:32px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2"
                                 style="width:32px; height:32px; font-size:0.9rem; font-weight:bold;">
                                @char.ToUpperInvariant(r.Username[0])
                            </div>
                        }
                        <span>@r.Username</span>
                    </div>
                    <div class="btn-group">
                        <form asp-action="AcceptFriendRequest" method="post">
                            <input type="hidden" name="requesterId" value="@r.Id" />
                            <button class="btn btn-sm btn-success">Accept</button>
                        </form>
                        <form asp-action="DeclineFriendRequest" method="post" class="ms-2">
                            <input type="hidden" name="requesterId" value="@r.Id" />
                            <button class="btn btn-sm btn-danger">Decline</button>
                        </form>
                    </div>
                </li>
            }
        </ul>
    }

    @if (Model.OutgoingRequests.Any())
    {
        <h3>Pending Friend Requests</h3>
        <hr></hr>
        <ul class="list-group mb-4">
            @foreach (var o in Model.OutgoingRequests)
            {
                var imgSrc = (o.Picture != null && o.Picture.Length > 0)
                ? $"data:image/jpeg;base64,{Convert.ToBase64String(o.Picture)}"
                : null;

                <li class="list-group-item d-flex justify-content-between align-items-center">
                    <div class="d-flex align-items-center">
                        @if (imgSrc != null)
                        {
                            <img src="@imgSrc" class="rounded-circle me-2" style="width:32px; height:32px; object-fit: cover;" />
                        }
                        else
                        {
                            <div class="rounded-circle bg-secondary text-white d-flex align-items-center justify-content-center me-2"
                                 style="width:32px; height:32px; font-size:0.9rem; font-weight:bold;">
                                @char.ToUpperInvariant(o.Username[0])
                            </div>
                        }
                        <span>@o.Username</span>
                    </div>
                    <form asp-action="RemoveFriend" method="post">
                        <input type="hidden" name="friendId" value="@o.Id" />
                        <button class="btn btn-sm btn-warning">Cancel</button>
                    </form>
                </li>
            }
        </ul>
    }
</div>

<div id="searchResults"></div>
