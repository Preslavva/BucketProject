@model UserViewModel

<div class="account-container">
    <div class="account-form">

        <h2 class="text-center">Account Info</h2>

        <div class="text-center">
            @if (Model.Picture != null)
            {
                var base64 = Convert.ToBase64String(Model.Picture);
                var imgSrc = $"data:image/jpeg;base64,{base64}";
                <img src="@imgSrc" alt="Profile Picture" class="profile-pic" />
            }
            else
            {
                <p class="text-center">No profile picture uploaded.</p>
            }
        </div>

        <form asp-action="AddPhoto" asp-controller="User" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <label for="photoFile">Select a photo</label>
            <input type="file" name="photoFile" id="photoFile" accept="image/*" class="input-field" />

            <button type="submit" class="button">Upload</button>
        </form>


        <hr />

        <form asp-action="UpdateUsername" asp-controller="User" method="post">
            <label for="username">Username</label>
            <input type="text" name="newUsername" id="username" value="@Model.Username" class="input-field" />

            <button type="submit" class="button">Update Username</button>
        </form>

        <hr />

        <label>Email</label>
        <input type="text" value="@Model.Email" readonly class="input-field" />

        <label>Account Created</label>
        <input type="text" value="@Model.CreatedAt.ToString("yyyy-MM-dd")" readonly class="input-field" />

        <label>Nationality</label>
        <input type="text" value="@Model.Nationality" readonly class="input-field" />

        <label>Gender</label>
        <input type="text" value="@Model.Gender" readonly class="input-field" />

        <label>Date of Birth</label>
        <input type="text" value="@Model.DateOfBirth.ToString("yyyy-MM-dd")" readonly class="input-field" />
    </div>
</div>
