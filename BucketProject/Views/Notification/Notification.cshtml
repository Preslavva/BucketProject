@model List<NotificationViewModel>

<h2>Hello, @ViewBag.Username! Here are your notifications:</h2>

@if (!Model.Any())
{
    <div class="alert alert-success">
        You have no goals to be notified about today!
    </div>
}
else
{
    <ul class="list-group">
        @foreach (var item in Model)
        {
            <li class="list-group-item">

                <strong>@item.Description</strong><br />
                <span>@item.Message</span>

                @if (item.Recipients?.Any() == true)
                {
                    <div class="mt-2">
                        <small class="text-muted">
                            @(item.IsDone ? "Done by:" : "Shared with:")
                        </small>
                        @foreach (var u in item.Recipients)
                        {
                            <span class="ms-2 align-middle d-inline-flex">
                                @if (u.Picture != null && u.Picture.Length > 0)
                                {
                                    <img src="data:image/png;base64,@Convert.ToBase64String(u.Picture)"
                                         alt="@u.Username"
                                         width="24" height="24"
                                         class="rounded-circle me-1" />
                                }
                                else
                                {
                                    <div class="rounded-circle bg-secondary text-white
                                               d-flex align-items-center justify-content-center me-1"
                                         style="width:24px; height:24px; font-size:0.8rem;">
                                        @u.Username.Substring(0, 1).ToUpper()
                                    </div>
                                }
                                <span class="align-self-center">@u.Username</span>
                            </span>
                        }
                    </div>
                }

              
                @if (!item.IsDone && item.OwnerId == ViewBag.CurrentUserId)
                {
                    <form asp-action="PostponeGoal" method="post" style="margin-top: 10px;">
                        <input type="hidden" name="Id" value="@item.Id" />
                        <input type="hidden" name="Type" value="@item.Type" />
                        <input type="hidden" name="Description" value="@item.Description" />
                        <input type="hidden" name="Category" value="@item.Category" />
                        <input type="hidden" name="CreatedAt" value="@item.CreatedAt:yyyy-MM-ddTHH:mm:ss" />
                        <input type="hidden" name="Deadline" value="@item.Deadline:yyyy-MM-ddTHH:mm:ss" />
                        <input type="hidden" name="IsPostponed" value="true" />
                        <input type="hidden" name="IsDone" value="@item.IsDone" />
                        <input type="hidden" name="IsDeleted" value="@item.IsDeleted" />

                        <button type="submit" class="btn btn-warning btn-sm">Postpone</button>
                    </form>
                }
            </li>
        }
    </ul>
}
