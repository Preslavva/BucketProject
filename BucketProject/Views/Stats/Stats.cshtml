@{
    ViewData["Title"] = "Your Statistics";

    var hasGoals = (int)ViewBag.TotalGoals > 0;
    var hasTypeData = (ViewBag.TypeData as List<int> ?? new()).Any();
    var hasCategoryData = (ViewBag.CategoryData as List<int> ?? new()).Any();
    var hasWeeklyData = (ViewBag.WeekData as List<int> ?? new()).Any();
    var hasMonthlyData = (ViewBag.MonthData as List<int> ?? new()).Any();
    var hasYearlyData = (ViewBag.YearData as List<int> ?? new()).Any();
}

<h2 class="text-center mb-4">Your Statistics</h2>

<ul class="nav nav-tabs" id="statsTabs" role="tablist">
    <li class="nav-item">
        <button class="nav-link active" id="summary-tab" data-bs-toggle="tab" data-bs-target="#summary" type="button">Summary Circles</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="line-tab" data-bs-toggle="tab" data-bs-target="#line-graphs" type="button">Line Graphs</button>
    </li>
    <li class="nav-item">
        <button class="nav-link" id="pie-tab" data-bs-toggle="tab" data-bs-target="#pie-charts" type="button">Pie Charts</button>
    </li>
</ul>

<div class="tab-content mt-4">

    <div class="tab-pane fade show active" id="summary" role="tabpanel">
        @if (hasGoals)
        {
            <div class="circle-stats-container-primary">
                <div class="circle-wrapper"><div class="circle-stat total">@ViewBag.TotalGoals</div><div class="circle-label">Total Goals</div></div>
                <div class="circle-wrapper"><div class="circle-stat completed">@ViewBag.CompletedGoals</div><div class="circle-label">Completed</div></div>
                <div class="circle-wrapper"><div class="circle-stat incomplete">@ViewBag.IncompleteGoals</div><div class="circle-label">Incomplete</div></div>
            </div>

            <div class="circle-stats-container-secondary">
                <div class="circle-wrapper"><div class="circle-stat personal">@ViewBag.PersonalGoals</div><div class="circle-label">Personal Goals</div></div>
                <div class="circle-wrapper"><div class="circle-stat shared">@ViewBag.SharedGoals</div><div class="circle-label">Shared Goals</div></div>
                <div class="circle-wrapper"><div class="circle-stat postponed">@ViewBag.PostponedGoals</div><div class="circle-label">Postponed Goals</div></div>
                <div class="circle-wrapper"><div class="circle-stat ai">@ViewBag.AIGoals</div><div class="circle-label">AI Generated</div></div>
                <div class="circle-wrapper"><div class="circle-stat average">@ViewBag.AverageCompletionDays</div><div class="circle-label">Avg Completion Days</div></div>
            </div>
        }
        else
        {
            <p class="text-center">You don't have any goals yet.</p>
        }
    </div>

   
    <div class="tab-pane fade" id="line-graphs" role="tabpanel">

        <ul class="nav nav-tabs justify-content-center mb-3" id="goalTab" role="tablist">
            <li class="nav-item">
                <button class="nav-link active" data-bs-toggle="tab" data-bs-target="#weekly-goals" type="button" role="tab">By Week</button>

            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#monthly-goals" type="button" role="tab">By Month</button>
            </li>
            <li class="nav-item">
                <button class="nav-link" data-bs-toggle="tab" data-bs-target="#yearly-goals" type="button" role="tab">By Year</button>
            </li>
        </ul>

        <div class="tab-content">

            <div class="tab-pane fade show active text-center" id="weekly-goals" role="tabpanel">
                @if (hasWeeklyData)
                {
                    <canvas id="weeklyChart" class="chart-canvas"></canvas>
                    <div class="text-center mt-3">
                        <span class="text-muted">@ViewBag.WeekMessage</span>
                    </div>

                }
                else
                {
                    <br></br>
                    <p class="text-center">No data available for weekly goal completions</p>
                }
            </div>

            <div class="tab-pane fade text-center" id="monthly-goals" role="tabpanel">
                @if (hasMonthlyData)
                {
                    <canvas id="monthlyChart" class="chart-canvas"></canvas>
                    <div class="text-center mt-3">
                        <span class="text-muted">@ViewBag.MonthMessage</span>
                    </div>
                }
                else
                {
                    <br></br>
                    <p class="text-center">No data available for monthly goal completions.</p>
                }
            </div>

            <div class="tab-pane fade text-center" id="yearly-goals" role="tabpanel">
                @if (hasYearlyData)
                {
                    <canvas id="yearlyChart" class="chart-canvas"></canvas>
                    <div class="text-center mt-3">
                        <span class="text-muted">@ViewBag.YearMessage</span>
                    </div>
                }
                else
                {
                    <br></br>
                    <p class="text-center">No data available for yearly goal completions.</p>
                }
            </div>

        </div>

    </div>


  
    <div class="tab-pane fade" id="pie-charts" role="tabpanel">
        <div class="d-flex flex-wrap gap-4 justify-content-center">
            @if (hasTypeData)
            {
                <canvas id="goalTypeChart" width="400" height="400"></canvas>
            }
            @if (hasCategoryData)
            {
                <canvas id="goalCategoryChart" width="400" height="400"></canvas>
            }
            @if (!hasTypeData && !hasCategoryData)
            {
                <p class="text-center">You don't have any goals yet.</p>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @if (hasWeeklyData)
    {
        <script>
            new Chart(document.getElementById('weeklyChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.WeekLabels)),
                    datasets: [{
                        label: 'Completed (Weekly)',
                        data: @Html.Raw(Json.Serialize(ViewBag.WeekData)),
                        fill: true,
                        borderColor: 'rgba(75, 192, 192, 1)',
                        backgroundColor: 'rgba(75, 192, 192, 0.2)',
                        tension: 0.3,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        title: { display: true, text: 'Completed Goals Per Week' },
                        legend: { position: 'bottom' }
                    },
                                scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1,
                        callback: function(value) {
                            return Number.isInteger(value) && value > 0 ? value : '';
                        }
                    }
                }
            }

                }
            });
        </script>

      


    }

    @if (hasMonthlyData)
    {
        <script>
            new Chart(document.getElementById('monthlyChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.MonthLabels)),
                    datasets: [{
                        label: 'Completed (Monthly)',
                        data: @Html.Raw(Json.Serialize(ViewBag.MonthData)),
                        fill: true,
                        borderColor: 'rgba(153, 102, 255, 1)',
                        backgroundColor: 'rgba(153, 102, 255, 0.2)',
                        tension: 0.3,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        title: { display: true, text: 'Completed Goals Per Month' },
                        legend: { position: 'bottom' }
                    },
                               scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1,
                        callback: function(value) {
                            return Number.isInteger(value) && value > 0 ? value : '';
                        }
                    }
                }
            }

                }
            });
        </script>
    }

    @if (hasYearlyData)
    {
        <script>
            new Chart(document.getElementById('yearlyChart').getContext('2d'), {
                type: 'line',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.YearLabels)),
                    datasets: [{
                        label: 'Completed (Yearly)',
                        data: @Html.Raw(Json.Serialize(ViewBag.YearData)),
                        fill: true,
                        borderColor: 'rgba(255, 159, 64, 1)',
                        backgroundColor: 'rgba(255, 159, 64, 0.2)',
                        tension: 0.3,
                        pointRadius: 3
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        title: { display: true, text: 'Completed Goals Per Year' },
                        legend: { position: 'bottom' }
                    },
                               scales: {
                y: {
                    beginAtZero: true,
                    ticks: {
                        stepSize: 1,
                        callback: function(value) {
                            return Number.isInteger(value) && value > 0 ? value : '';
                        }
                    }
                }
            }

                }
            });
        </script>
    }

    @if (hasTypeData)
    {
        <script>
            new Chart(document.getElementById('goalTypeChart').getContext('2d'), {
                type: 'pie',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.TypeLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.TypeData)),
                                backgroundColor: [
            '#FFB3BA',
            '#FFDFBA', 
            '#FFFFBA', 
            '#BAFFC9',
            '#BAE1FF'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: false,
                    plugins: {
                        title: { display: true, text: 'Top 5 Goal Types' },
                        legend: { position: 'bottom' }
                    }
                }
            });
        </script>
    }

    @if (hasCategoryData)
    {
        <script>
            new Chart(document.getElementById('goalCategoryChart').getContext('2d'), {
                type: 'pie',
                data: {
                    labels: @Html.Raw(Json.Serialize(ViewBag.CategoryLabels)),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(ViewBag.CategoryData)),
                        backgroundColor: ['#D5F4E6', '#FFDAC1', '#CBAACB', '#B5EAD7'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: false,
                    plugins: {
                        title: { display: true, text: 'Goals by Category' },
                        legend: { position: 'bottom' }
                    }
                }
            });
        </script>
    }
}
